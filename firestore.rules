rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if ID is alpha-numeric/hyphens/underscores
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 64;
    }

    // Helper to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Top-level players collection for global registrations
    match /players/{playerId} {
      allow read: if true;
      allow write: if isValidId(playerId);
    }

    // Matches the tournament container
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create, update, delete: if isValidId(tournamentId);

      // Sub-collections inside tournaments
      match /players/{playerId} {
        allow read: if true;
        // The tournament owner or any authorized player can register
        allow write: if isValidId(playerId);
      }

      match /matches/{matchId} {
        allow read: if true;
        // The tournament owner can record results or create pairings
        allow write: if isValidId(matchId);
      }

      match /notifications/{notificationId} {
        allow read: if true;
        allow write: if isValidId(notificationId);
      }
    }
  }
}
